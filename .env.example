APP_NAME=serv-found

# App Enable Switches (true/false) — 与 service_foundation 同风格
APP_CONSOLE_ENABLED=true
APP_WORLD_CUP_ENABLED=true
APP_PLATFORM_LAB_ENABLED=true

DEBUG=true

HOST=127.0.0.1
PORT=8000


ALLOWED_HOSTS=localhost,127.0.0.1


# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=athena
DB_USER=zhang
DB_PASSWORD=123456
DB_TEST_NAME=athena_test

# aigc
